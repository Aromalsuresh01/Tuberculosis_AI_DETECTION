# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — AI TB Detection System
# Prevents large/sensitive files from being committed to GitHub
# ─────────────────────────────────────────────────────────────────────────────

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyo
.Python

# Virtual environments
venv/
.venv/
env/
ENV/

# IDE / editor settings
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Environment variables / secrets
.env
*.env
*.env.local

# Dataset images and annotations (large files — download via Roboflow)
data/train/
data/val/
data/test/
new_data/

# Model weight files (large binaries — store on HuggingFace / releases)
models/*.pt
models/*.pth
models/*.onnx
models/*.engine

# Training run artifacts (auto-generated by Ultralytics)
runs/
wandb/

# Output images with bounding box overlays
output/*.jpg
output/*.png

# Jupyter notebook checkpoints
.ipynb_checkpoints/
*.ipynb

# OS files
*.log
*.tmp
Thumbs.db

# Keep directory stubs (so empty folders are preserved in Git)
!data/.gitkeep
!models/.gitkeep
!output/.gitkeep
!reports/.gitkeep
!new_data/.gitkeep
